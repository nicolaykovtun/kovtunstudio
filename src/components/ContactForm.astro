---
interface Props {
  data: {
    title: string;
    intro: string;
    telegramTitle: string;
    maxTitle: string;
    formTitle: string;
    fields: {
      name: { label: string; placeholder: string };
      car: { label: string; placeholder: string };
      message: { label: string; placeholder: string };
    };
    privacy: string;
    submit: string;
    successTitle: string;
    successText: string;
    reopen: string;
    resetText: string;
  };
  telegramUrl: string;
  telegramHandle: string;
  maxUrl: string;
  maxHandle: string;
}
const { data, telegramUrl, maxUrl } = Astro.props;
---
<section class="cta-section" id="contact">
  <div class="container-wide">
    <div class="cta-wrap">
      <div class="pitch">
        <h2 style="margin-top:0">{data.title}</h2>
        <p>{data.intro}</p>

        <div class="messenger-links">
          <a href={telegramUrl} target="_blank" rel="noopener" class="telegram-direct">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M21.5 4.2 2.6 11.5c-1.3.5-1.3 1.2-.2 1.5l4.8 1.5 11.1-7c.5-.3 1 .1.6.4l-9 8.1-.3 4.7c.5 0 .7-.2 1-.5l2.4-2.3 5 3.7c.9.5 1.6.2 1.9-.9l3.3-15.6c.4-1.4-.5-2-1.7-1.5z"/>
            </svg>
            {data.telegramTitle}
          </a>

          <a href={maxUrl} target="_blank" rel="noopener" class="telegram-direct max-direct">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
            {data.maxTitle}
          </a>
        </div>
      </div>

      <form class="k-form" id="lead-form" novalidate>
        <div id="form-fields">
          <div class="form-head">
            <span class="overline">Заявка</span>
            <h3>{data.formTitle}</h3>
          </div>
          <div class="field-row">
            <div class="field">
              <input type="text" id="f-name" placeholder={data.fields.name.placeholder} autocomplete="name">
              <label class="lbl" for="f-name">{data.fields.name.label}</label>
              <span class="field-error" id="err-name" hidden></span>
            </div>
            <div class="field">
              <input type="text" id="f-car" placeholder={data.fields.car.placeholder}>
              <label class="lbl" for="f-car">{data.fields.car.label}</label>
              <span class="field-error" id="err-car" hidden></span>
            </div>
          </div>
          <div class="field">
            <textarea id="f-message" placeholder={data.fields.message.placeholder} rows="3"></textarea>
            <label class="lbl" for="f-message">{data.fields.message.label}</label>
          </div>

          <!-- Одна главная кнопка отправки (Telegram) -->
          <button type="submit" class="btn btn-primary btn-send" data-target="telegram">
            {data.submit} <span class="arrow" aria-hidden="true">→</span>
          </button>

          <!-- MAX — тихая текстовая ссылка, а не вторая равная кнопка -->
          <button type="submit" class="max-quiet-link" data-target="max">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
            {data.maxTitle}
          </button>

          <!-- Privacy текст под кнопками -->
          <div class="privacy">{data.privacy}</div>
        </div>

        <!-- Успешная отправка -->
        <div id="form-success" hidden>
          <div class="success-head">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12l5 5L20 6"/></svg>
            <h3 id="success-title">{data.successTitle}</h3>
          </div>
          <p id="success-text">{data.successText}</p>

          <!-- Блок копирования текста (только для MAX) -->
          <div class="copy-text-block" id="copy-text-block" hidden>
            <textarea id="copy-text-area" readonly></textarea>
            <button type="button" class="copy-icon-btn" id="copy-text-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="13" height="13"/><rect x="8" y="8" width="13" height="13"/></svg>
              <span id="copy-text-btn-label">Скопировать текст</span>
            </button>
          </div>

          <a href="#" id="reopen-messenger" target="_blank" rel="noopener" class="btn btn-white">
            {data.reopen} <span class="arrow" aria-hidden="true">→</span>
          </a>
          <button type="button" id="form-reset">
            {data.resetText}
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  /* Две ссылки на мессенджеры в pitch-блоке, с заметным отступом */
  .messenger-links {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 32px;
  }
  .max-direct { margin-top: 0; }  /* отступ задаётся через gap у .messenger-links */

  /* Privacy текст под кнопками */
  #form-fields .privacy {
    margin-top: 0;
    font: 400 12px/1.5 var(--font-body);
    color: var(--fg-3);
  }

  /* Блок копирования для MAX-flow — одна компактная строка на красной панели.
     :not([hidden]) — чтобы атрибут hidden реально скрывал блок для Telegram-flow. */
  .copy-text-block:not([hidden]) {
    display: flex;
    align-items: stretch;
    gap: 8px;
  }
  .copy-text-block textarea {
    flex: 1;
    min-height: 64px;
    border: 1px solid rgba(255,255,255,.4);
    padding: 10px 12px;
    font: 400 13px/1.4 var(--font-body);
    color: #fff;
    background: rgba(0,0,0,.14);
    resize: vertical;
    box-sizing: border-box;
  }
  .copy-icon-btn {
    flex-shrink: 0;
    display: flex; align-items: center; gap: 8px;
    padding: 0 12px;
    background: rgba(255,255,255,.14);
    border: 1px solid rgba(255,255,255,.4);
    color: #fff;
    font: 600 12px/1 var(--font-body);
    cursor: pointer;
  }
  .copy-icon-btn:hover { background: rgba(255,255,255,.22); }
  .copy-icon-btn svg { width: 15px; height: 15px; flex-shrink: 0; }
</style>
