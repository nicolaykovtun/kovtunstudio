---
interface Props {
  data: {
    title: string;
    intro: string;
    telegramTitle: string;
    maxTitle: string;
    formTitle: string;
    fields: {
      name: { label: string; placeholder: string };
      car: { label: string; placeholder: string };
      message: { label: string; placeholder: string };
    };
    privacy: string;
    submit: string;
    successTitle: string;
    successText: string;
    reopen: string;
    resetText: string;
  };
  telegramUrl: string;
  telegramHandle: string;
  maxUrl: string;
  maxHandle: string;
}
const { data, telegramUrl, maxUrl } = Astro.props;
---
<section class="cta-section" id="contact">
  <div class="container-wide">
    <div class="cta-wrap">
      <div class="pitch">
        <h2 style="margin-top:0">{data.title}</h2>
        <p>{data.intro}</p>

        <div class="messenger-links">
          <a href={telegramUrl} target="_blank" rel="noopener" class="telegram-direct">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M21.5 4.2 2.6 11.5c-1.3.5-1.3 1.2-.2 1.5l4.8 1.5 11.1-7c.5-.3 1 .1.6.4l-9 8.1-.3 4.7c.5 0 .7-.2 1-.5l2.4-2.3 5 3.7c.9.5 1.6.2 1.9-.9l3.3-15.6c.4-1.4-.5-2-1.7-1.5z"/>
            </svg>
            {data.telegramTitle}
          </a>

          <a href={maxUrl} target="_blank" rel="noopener" class="telegram-direct max-direct">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
            {data.maxTitle}
          </a>
        </div>
      </div>

      <form class="k-form" id="lead-form" novalidate>
        <div id="form-fields">
          <div class="form-head">
            <h3>{data.formTitle}</h3>
          </div>
          <div class="field">
            <input type="text" id="f-name" placeholder={data.fields.name.placeholder} autocomplete="name">
            <label class="lbl" for="f-name">{data.fields.name.label}</label>
            <span class="field-error" id="err-name" hidden></span>
          </div>
          <div class="field">
            <input type="text" id="f-car" placeholder={data.fields.car.placeholder}>
            <label class="lbl" for="f-car">{data.fields.car.label}</label>
            <span class="field-error" id="err-car" hidden></span>
          </div>
          <div class="field">
            <textarea id="f-message" placeholder={data.fields.message.placeholder} rows="3"></textarea>
            <label class="lbl" for="f-message">{data.fields.message.label}</label>
          </div>

          <!-- Кнопки сабмита: Telegram (основная) + MAX (вторая) -->
          <div class="submit-buttons">
            <button type="submit" class="btn submit-btn" data-target="telegram">
              Отправить в Telegram <span class="arrow" aria-hidden="true">→</span>
            </button>
            <button type="submit" class="btn submit-btn submit-btn-max" data-target="max">
              Отправить в MAX <span class="arrow" aria-hidden="true">→</span>
            </button>
          </div>

          <!-- Privacy текст под кнопками -->
          <div class="privacy">{data.privacy}</div>
        </div>

        <!-- Успешная отправка -->
        <div id="form-success" hidden>
          <div class="form-head">
            <h3 id="success-title">{data.successTitle}</h3>
          </div>
          <div class="success" id="success-text">{data.successText}</div>

          <!-- Блок копирования текста (только для MAX) -->
          <div class="copy-text-block" id="copy-text-block" hidden>
            <div class="copy-text-label">Текст заявки:</div>
            <textarea id="copy-text-area" readonly></textarea>
            <button type="button" class="btn btn-dark" id="copy-text-btn" style="justify-content:center">
              <span id="copy-text-btn-label">Скопировать текст</span>
            </button>
          </div>

          <a href="#" id="reopen-messenger" target="_blank" rel="noopener" class="btn btn-dark" style="justify-content:center">
            {data.reopen} <span class="arrow" aria-hidden="true">→</span>
          </a>
          <button type="button" id="form-reset" style="background:none;border:0;color:var(--fg-3);font:500 13px/1 var(--font-display);letter-spacing:0.08em;text-transform:uppercase;text-align:left;padding:8px 0;cursor:pointer">
            {data.resetText}
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  /* Две ссылки на мессенджеры в pitch-блоке, с заметным отступом */
  .messenger-links {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 32px;
  }
  .max-direct { margin-top: 0; }  /* отступ задаётся через gap у .messenger-links */

  /* Кнопки сабмита: одна над другой на мобайле, в ряд на десктопе */
  .submit-buttons {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 16px;
  }
  @media (min-width: 640px) {
    .submit-buttons { flex-direction: row; flex-wrap: wrap; }
  }
  .submit-btn-max {
    background: var(--ks-charcoal);
    color: #fff;
  }
  .submit-btn-max:hover { background: var(--ks-charcoal-700); }

  /* Privacy текст */
  .submit-row,
  #form-fields .privacy {
    margin-top: 16px;
    font: 400 12px/1.5 var(--font-body);
    color: var(--fg-3);
  }

  /* Блок копирования для MAX-flow */
  .copy-text-block {
    margin: 16px 0;
    padding: 16px;
    background: var(--bg-2);
    border-radius: var(--r-2);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .copy-text-label {
    font: 700 12px/1.2 var(--font-display);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .copy-text-block textarea {
    width: 100%;
    min-height: 120px;
    border: 1px solid var(--line-1);
    border-radius: var(--r-2);
    padding: 12px;
    font: 400 14px/1.5 var(--font-body);
    color: var(--fg-1);
    background: var(--bg-1);
    resize: vertical;
    box-sizing: border-box;
  }
</style>
