---
import fs from 'node:fs';
import path from 'node:path';
import crypto from 'node:crypto';

interface Point {
  num: string;
  title: string;
  text: string;
}

interface Stat {
  num: string;
  label: string;
}

interface Props {
  data: {
    title: string;
    aside: string;
    name: string;
    role: string;
    text: string;
    stats: Stat[];
    points: Point[];
    // Фото пока не добавлено — поля появятся в site.yaml, когда фото будет готово.
    image?: string;
    imageAlt?: string;
  };
}

const { data } = Astro.props;

// Хэш файла в query-строке — чтобы при замене фото под тем же именем
// браузеры и CDN не отдавали закэшированную старую версию.
const imageVersion = data.image
  ? crypto.createHash('md5').update(fs.readFileSync(path.resolve('./public', data.image))).digest('hex').slice(0, 8)
  : null;
---
<section class="section founder-section" id="founder">
  <div class="container-wide">
    <div class="section-head">
      <div>
        <h2 set:html={data.title}></h2>
      </div>
      <p class="aside">{data.aside}</p>
    </div>

    <div class="founder-grid">
      <div class="founder-intro">
        {data.image && (
          <img src={`/${data.image}?v=${imageVersion}`} alt={data.imageAlt || data.name} class="founder-photo" width="220" height="385" loading="lazy" />
        )}
        <div class="founder-lead">
          <p class="overline">{data.role}</p>
          <h3>{data.name}</h3>
          <p>{data.text}</p>
          <div class="founder-stats" aria-label="Опыт в цифрах">
            {data.stats.map(stat => (
              <div class="item">
                <span class="num">{stat.num}</span>
                <span class="lbl">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="founder-points" aria-label="Как устроена работа">
        {data.points.map(point => (
          <div class="founder-point">
            <div class="founder-point-num">{point.num}</div>
            <h4>{point.title}</h4>
            <p>{point.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
