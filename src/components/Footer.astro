---
interface Column {
  title: string;
  links?: { href: string; label: string; external?: boolean }[];
  info?: string[];
}
interface Props {
  tagline: string;
  columns: Column[];
  copy: string;
  copyTagline: string;
}
const { tagline, columns, copy, copyTagline } = Astro.props;
const year = new Date().getFullYear();
const copyText = copy.replace('{year}', String(year));
---
<footer class="k-footer">
  <div class="container-wide">
    <div class="top">
      <div>
        <span class="brand"><img src="/assets/logo-on-dark.svg" alt="Kovtun.studio"></span>
        <p class="tag">{tagline}</p>
      </div>
      {columns.map(col => (
        <div>
          <h4>{col.title}</h4>
          {col.links?.map(link => (
            link.external
              ? <a href={link.href} target="_blank" rel="noopener">{link.label}</a>
              : <a href={link.href}>{link.label}</a>
          ))}
          {col.info?.map(line => <span class="v">{line}</span>)}
        </div>
      ))}
    </div>
    <div class="bottom">
      <span>{copyText}</span>
      <span>{copyTagline}</span>
    </div>
  </div>
</footer>
